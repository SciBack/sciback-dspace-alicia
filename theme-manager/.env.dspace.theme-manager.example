# perfil del theme
DSPACE_THEME_PROFILE="sciback_theme_dspace7"
DSPACE_THEME_DISPLAY_NAME="SciBack Theme DSpace 7"

# frontend real
DSPACE_FRONTEND_DIR="/home/dspace/frontend"

# themes
DSPACE_BASE_THEME_NAME="dspace"
DSPACE_TARGET_THEME_NAME="sciback_theme_dspace7"
DSPACE_BASE_THEME_DIR="/home/dspace/frontend/src/themes/dspace"
DSPACE_TARGET_THEME_DIR="/home/dspace/frontend/src/themes/sciback_theme_dspace7"

# config de activación
DSPACE_DEFAULT_APP_CONFIG_FILE="/home/dspace/frontend/src/config/default-app-config.ts"

# assets del nuevo theme
DSPACE_TARGET_THEME_ASSETS_DIR="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets"
DSPACE_TARGET_THEME_IMAGES_DIR="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images"
DSPACE_TARGET_THEME_FAVICONS_DIR="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images/favicons"

# archivos de estilos y templates del nuevo theme
DSPACE_THEME_SCSS_VARIABLE_OVERRIDES_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/styles/_theme_sass_variable_overrides.scss"
DSPACE_THEME_CSS_VARIABLE_OVERRIDES_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/styles/_theme_css_variable_overrides.scss"
DSPACE_THEME_NAVBAR_HTML_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/app/navbar/navbar.component.html"
DSPACE_THEME_NAVBAR_SCSS_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/app/navbar/navbar.component.scss"
DSPACE_THEME_HEADER_HTML_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/app/header/header.component.html"
DSPACE_THEME_HEADER_SCSS_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/app/header/header.component.scss"

# footer personalizado
DSPACE_THEME_FOOTER_HTML_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/app/footer/footer.component.html"
DSPACE_THEME_FOOTER_SCSS_FILE="/home/dspace/frontend/src/themes/sciback_theme_dspace7/app/footer/footer.component.scss"
DSPACE_THEME_CREATE_FOOTER_IF_MISSING=true

# activos fuente externos
DSPACE_THEME_SOURCE_ASSETS_DIR="/home/dspace/theme-manager/assets"
DSPACE_THEME_LOGO_SOURCE="/home/dspace/theme-manager/assets/logo.png"
DSPACE_THEME_BANNER_SOURCE="/home/dspace/theme-manager/assets/banner.png"
DSPACE_THEME_FAVICON_ICO_SOURCE="/home/dspace/theme-manager/assets/favicon.ico"
DSPACE_THEME_FAVICON_SVG_SOURCE="/home/dspace/theme-manager/assets/favicon.svg"
DSPACE_THEME_APPLE_TOUCH_ICON_SOURCE="/home/dspace/theme-manager/assets/apple-touch-icon.png"
DSPACE_THEME_WEBMANIFEST_SOURCE="/home/dspace/theme-manager/assets/manifest.webmanifest"

# destinos en el theme copiado
DSPACE_THEME_LOGO_TARGET="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images/logo.png"
DSPACE_THEME_BANNER_TARGET="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images/banner.png"
DSPACE_THEME_FAVICON_ICO_TARGET="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images/favicons/favicon.ico"
DSPACE_THEME_FAVICON_SVG_TARGET="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images/favicons/favicon.svg"
DSPACE_THEME_APPLE_TOUCH_ICON_TARGET="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images/favicons/apple-touch-icon.png"
DSPACE_THEME_WEBMANIFEST_TARGET="/home/dspace/frontend/src/themes/sciback_theme_dspace7/assets/images/favicons/manifest.webmanifest"

# colores institucionales
DSPACE_THEME_PRIMARY="#003366"
DSPACE_THEME_SECONDARY="#0055aa"
DSPACE_THEME_ACCENT="#ffcc00"

# footer
DSPACE_THEME_FOOTER_TEXT="SciBack Open Science Infrastructure"
DSPACE_THEME_FOOTER_HTML=""

# menús / políticas
ENABLE_ALICIA_POLICY_MENU=true
ENABLE_PRIVACY_MENU=true
ENABLE_TERMS_MENU=true
DSPACE_POLICY_ALICIA_URL="/page/alicia"
DSPACE_POLICY_PRIVACY_URL="/page/privacy"
DSPACE_POLICY_TERMS_URL="/page/terms"

# dominio opcional para regex theme
DSPACE_THEME_REGEX=".*"
DSPACE_THEME_USE_REGEX=false

# build / pm2
DSPACE_RUN_YARN_INSTALL=false
DSPACE_YARN_INSTALL_COMMAND="yarn install --frozen-lockfile"
DSPACE_YARN_BUILD_COMMAND="yarn build"
DSPACE_PM2_APP_NAME="all"

# comportamiento
DSPACE_RUN_AS_USER="dspace"
CREATE_BACKUPS=true
STRICT_PATH_VALIDATION=true
OVERWRITE_EXISTING_THEME=false
AUTO_BUILD_ON_FULL_RUN=true
AUTO_RESTART_ON_FULL_RUN=true

# logs / backups
DSPACE_THEME_WORKDIR="/home/dspace/theme-manager"
DSPACE_THEME_BACKUP_DIR="/home/dspace/theme-manager/backups"
DSPACE_THEME_LOG_DIR="/home/dspace/theme-manager/logs"
LOG_FILE="/home/dspace/theme-manager/logs/theme-manager.log"
