# =============================================================================
# SciBack — DSpace 7.6.6 + ALICIA/RENATI
# Copiar a .env.deploy y editar con datos reales
# =============================================================================

# ─── Cliente / Entorno ─────────────────────────────────────
SCIBACK_CLIENT="mi-universidad"
SCIBACK_ENV="prod"
DSPACE_VERSION="7.6.6"
TIMEZONE="America/Lima"
CRON_TIMEZONE="America/Lima"

# ─── Usuarios / rutas base ─────────────────────────────────
DSPACE_RUN_AS_USER="dspace"
DSPACE_RUN_AS_GROUP="dspace"

DSPACE_DIR="/dspace"
DSPACE_SRC_DIR="/home/dspace/dspace-src"
DSPACE_FRONTEND_DIR="/home/dspace/frontend"

DSPACE_NAME="Repositorio Institucional"
DSPACE_HOSTNAME="repositorio.mi-universidad.edu.pe"

# ─── Base de datos ─────────────────────────────────────────
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="dspace"
DB_USER="dspace"
DB_PASSWORD="CAMBIAR_PASSWORD_SEGURO"
DB_LOCALE="es_PE.UTF-8"

# ─── Solr ──────────────────────────────────────────────────
SOLR_VERSION="8.11.4"
SOLR_HEAP_MIN="1024m"
SOLR_HEAP_MAX="2048m"
SOLR_URL="http://localhost:8983/solr"
SOLR_BIN="/opt/solr/bin/solr"

# ─── Tomcat ────────────────────────────────────────────────
TOMCAT_VERSION="9.0.97"
TOMCAT_HEAP_MIN="1536m"
TOMCAT_HEAP_MAX="3072m"
TOMCAT_WEBAPPS_DIR="/opt/tomcat9/webapps"

# ─── Backend build/install ─────────────────────────────────
# DSPACE_INSTALL_MODE="fresh_install" solo en primera corrida limpia
# luego, si reejecutas etapa 06 sobre una instalación ya montada, cambiar a:
# DSPACE_INSTALL_MODE="update"
DSPACE_INSTALL_MODE="fresh_install"
DSPACE_MAVEN_BUILD_ARGS="-DskipTests"
DSPACE_REST_API_BASE="http://localhost:8080/server/api"
INSTALL_SCHEMAS_ALICIA="yes"
INSTALL_FORMULARIOS="yes"

# ─── Frontend / Node / PM2 ────────────────────────────────
NODE_MAJOR="20"
PM2_INSTANCES="3"
PM2_MAX_MEMORY="1500M"
PM2_PORT="4000"
DSPACE_PM2_APP_NAME="dspace-mi-universidad"
DSPACE_NODE_TLS_REJECT_UNAUTHORIZED="1"

# ─── Handle ────────────────────────────────────────────────
HANDLE_PREFIX="20.500.XXXXX"
HANDLE_VERSION="9.3.1"
HANDLE_INSTALL_DIR="/opt/handle"

# ─── Email ─────────────────────────────────────────────────
MAIL_SERVER="smtp.gmail.com"
MAIL_PORT="587"
MAIL_FROM="repositorio@mi-universidad.edu.pe"
MAIL_ADMIN="repositorio@mi-universidad.edu.pe"
MAIL_USERNAME="repositorio@mi-universidad.edu.pe"
MAIL_PASSWORD="CAMBIAR_APP_PASSWORD"

# ─── Admin DSpace ──────────────────────────────────────────
ADMIN_EMAIL="repositorio@mi-universidad.edu.pe"
ADMIN_PASSWORD="CAMBIAR_PASSWORD_SEGURO"
ADMIN_FIRSTNAME="Admin"
ADMIN_LASTNAME="Repo"
ADMIN_LANGUAGE="es"

# ─── SSL / Certbot / Nginx ────────────────────────────────
CERTBOT_EMAIL="soporte@mi-empresa.com"
CERTBOT_AUTO="true"
NGINX_CLIENT_MAX_BODY_SIZE="1024m"

# ─── Cosechadores / acceso OAI ─────────────────────────────
HARVESTER_IPS="200.48.14.0/24 200.48.15.0/24 200.48.47.0/24"

# ─── Sistema ───────────────────────────────────────────────
SWAP_SIZE="4G"

# ─── Flags de instalación por etapa ───────────────────────
INSTALL_DSPACE="yes"
INSTALL_FRONTEND="yes"
INSTALL_NGINX="yes"
INSTALL_HANDLE="yes"

# ─── Estructura inicial SciBack Lab (Etapa 14) ────────────
LAB_STRUCTURE="false"
LAB_ROOT_COMMUNITY="SciBack Open Science Lab"
LAB_SUBCOMMUNITIES="Demonstration Collections|Metadata Experiments|Software Platforms"
LAB_COLLECTIONS__DEMONSTRATION_COLLECTIONS="Sample Articles|Sample Theses|Sample Datasets"
LAB_COLLECTIONS__METADATA_EXPERIMENTS="ALICIA / RENATI tests|OpenAIRE compatibility"
LAB_COLLECTIONS__SOFTWARE_PLATFORMS="DSpace tests|OJS tests|Interoperability tests"
LAB_REPOSITORY_DESCRIPTION="Plataforma de demostracion tecnologica desarrollada por SciBack para evaluar soluciones de infraestructura de investigacion basadas en software libre como DSpace, OJS y otros sistemas academicos."
