# =============================================================================
# SciBack — DSpace 7.6.6 + ALICIA/RENATI
# Copiar a .env.dspace.deploy y editar con datos reales
# =============================================================================

SCIBACK_CLIENT=mi-universidad
SCIBACK_ENV=prod
DSPACE_VERSION=7.6.6

DSPACE_DIR=/dspace
DSPACE_NAME="Repositorio Institucional"
DSPACE_HOSTNAME=repositorio.mi-universidad.edu.pe

DB_HOST=localhost
DB_PORT=5432
DB_NAME=dspace
DB_USER=dspace
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO
DB_LOCALE=es_PE.UTF-8

SOLR_VERSION=8.11.4
SOLR_HEAP_MIN=1024m
SOLR_HEAP_MAX=2048m

TOMCAT_VERSION=9.0.97
TOMCAT_HEAP_MIN=1536m
TOMCAT_HEAP_MAX=3072m

NODE_MAJOR=20
PM2_INSTANCES=3
PM2_MAX_MEMORY=1500M
PM2_PORT=4000

HANDLE_PREFIX=20.500.XXXXX
HANDLE_VERSION=9.3.1

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=repositorio@mi-universidad.edu.pe
MAIL_ADMIN=repositorio@mi-universidad.edu.pe

ADMIN_EMAIL=repositorio@mi-universidad.edu.pe
ADMIN_PASSWORD=CAMBIAR_PASSWORD_SEGURO
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=Repo
ADMIN_LANGUAGE=es

CERTBOT_EMAIL=soporte@mi-empresa.com
CERTBOT_AUTO=true

HARVESTER_IPS="200.48.14.0/24 200.48.15.0/24 200.48.47.0/24"

SWAP_SIZE=4G

TIMEZONE=America/Lima

# ─── Estructura inicial SciBack Lab (Etapa 14) ─────────────
LAB_STRUCTURE="false"
LAB_ROOT_COMMUNITY="SciBack Open Science Lab"
LAB_SUBCOMMUNITIES="Demonstration Collections|Metadata Experiments|Software Platforms"
LAB_COLLECTIONS__DEMONSTRATION_COLLECTIONS="Sample Articles|Sample Theses|Sample Datasets"
LAB_COLLECTIONS__METADATA_EXPERIMENTS="ALICIA / RENATI tests|OpenAIRE compatibility"
LAB_COLLECTIONS__SOFTWARE_PLATFORMS="DSpace tests|OJS tests|Interoperability tests"
LAB_REPOSITORY_DESCRIPTION="Plataforma de demostración tecnológica desarrollada por SciBack para evaluar soluciones de infraestructura de investigación basadas en software libre como DSpace, OJS y otros sistemas académicos."
